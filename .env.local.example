# ─── Supabase (lead storage) ───────────────────────────────────────────────────
# 1. Crea un proyecto en https://supabase.com
# 2. Settings → API → Project URL y Service Role Key
# 3. Pega los valores aquí (sin comillas)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Telegram (instant lead notifications) ─────────────────────────────────────
# 1. Telegram → busca "@BotFather" → /newbot → guarda el token
# 2. Manda /start a tu bot
# 3. Visita https://api.telegram.org/bot<TU_TOKEN>/getUpdates → copia el "chat":{"id": ... }
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
