# ─── Supabase (lead storage) ───────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Telegram (instant lead notifications) ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Site & conversion (client-safe NEXT_PUBLIC_*) ───────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.wiainnercircle.com

# Calendly embed URL (aparece en /gracias tras aplicar)
# Ej: https://calendly.com/tu-usuario/15min?hide_gdpr_banner=1
NEXT_PUBLIC_CALENDLY_URL=

# Link público de invitación a tu canal de Telegram (NO el link de boost)
# Ej: https://t.me/+XXXXXXXXX
NEXT_PUBLIC_TELEGRAM_URL=

# ─── Analytics (opcional — activar cuando lances ads) ─────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# Meta Conversions API (server-side Lead — mejora atribución vs solo pixel)
# Generar en Meta Events Manager → Settings → Conversions API → Generate access token
META_CAPI_ACCESS_TOKEN=

# ─── WhatsApp bot en Railway (opcional — auto-mensaje tras aplicar) ───────────
# URL pública del servicio whatsapp-bot/ desplegado en Railway
WHATSAPP_BOT_URL=
# Mismo valor que INTERNAL_SECRET en Railway
WHATSAPP_BOT_SECRET=
